{
  "manifest_version": 3,
  "name": "Помощник для тестов",
  "version": "4.0.0",
  "description": "Расширение для прохождения тестов с ИИ и общей базой ответов",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Нажмите для управления"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "*://*.edu.rosminzdrav.ru/*",
    "*://*.onrender.com/*",
    "*://api.mistral.ai/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.edu.rosminzdrav.ru/*"
      ],
      "js": [
        "contentScript/supabase-config.js",
        "contentScript/utils.js",
        "contentScript/modal.js",
        "contentScript/api.js",
        "contentScript/handlers.js",
        "contentScript/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}